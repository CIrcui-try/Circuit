{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/.*/**" },
        { "path": "$HOME/**/.*" }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**", "app": true },
        { "path": "$HOME/**/.*/**", "app": true },
        { "path": "$HOME/**/.*", "app": true }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-confirm",
    "core:window:allow-set-badge-label",
    "store:default"
  ]
}
